  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT company_name, year,
       SUM(produced_million_m3) AS produced_million_m3
FROM [Egypt Water].[dbo].[Production_Records$]
GROUP BY company_name, year
ORDER BY year, company_name</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="company_name">
          <DataField>company_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="year">
          <DataField>year</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="produced_million_m3">
          <DataField>produced_million_m3</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
