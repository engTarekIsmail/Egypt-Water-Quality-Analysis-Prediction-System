  <DataSets>
    <DataSet Name="dsOverallKPIs">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT
  COUNT(DISTINCT c.company_id)                              AS total_companies,
  ROUND(SUM(pr.produced_million_m3), 0)                    AS total_production,
  ROUND(AVG(pr.loss_percentage), 1)                        AS avg_loss,
  ROUND(AVG(qt.compliance_rate_pct), 1)                    AS avg_compliance,
  SUM(c.population_2022)                                   AS total_population,
  COUNT(DISTINCT ws.source_id)                             AS total_sources
FROM [Egypt Water].[dbo].[Companies$]          c
JOIN [Egypt Water].[dbo].[Production_Records$] pr ON c.company_id = pr.company_id
                                               AND pr.year = 2022
JOIN [Egypt Water].[dbo].[Quality_Tests$]      qt ON c.company_id = qt.company_id
JOIN [Egypt Water].[dbo].[Water_Sources$]      ws ON c.company_id = ws.company_id</CommandText>
      </Query>
      <Fields>
        <Field Name="total_companies">
          <DataField>total_companies</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="total_production">
          <DataField>total_production</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="avg_loss">
          <DataField>avg_loss</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="avg_compliance">
          <DataField>avg_compliance</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="total_population">
          <DataField>total_population</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="total_sources">
          <DataField>total_sources</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsAlerts">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT alert_level, alert_message FROM (
  SELECT 'danger' AS alert_level,
         'Rural companies exceed 33% water loss — infrastructure review needed' AS alert_message,
         1 AS sort_order
  FROM [Egypt Water].[dbo].[Companies$]
  WHERE loss_percentage &gt; 33 AND company_type = 'Rural'
  HAVING COUNT(*) &gt; 0

  UNION ALL

  SELECT 'danger',
         'Coliform compliance below 90% national target',
         2
  FROM [Egypt Water].[dbo].[Quality_Tests$]
  HAVING AVG(compliance_rate_pct) &lt; 90

  UNION ALL

  SELECT 'warning',
         'Artesian sources show elevated nitrate — avg above 30 mg/L',
         3
  FROM [Egypt Water].[dbo].[Test_Records]
  WHERE source_type = 'Artesian'
  HAVING AVG(nitrate_mg_L) &gt; 30

  UNION ALL

  SELECT 'warning',
         'Summer turbidity peaks above 10 NTU in canal-fed systems',
         4
  FROM [Egypt Water].[dbo].[Test_Records]
  WHERE source_type = 'Canal' AND season = 'Summer'
  HAVING AVG(turbidity_NTU) &gt; 10

  UNION ALL

  SELECT 'success',
         'Nitrate compliance at 96%+ — best performing parameter',
         5
  FROM [Egypt Water].[dbo].[Test_Records]
  HAVING AVG(CAST(nitrate_compliant AS FLOAT))*100 &gt; 95

  UNION ALL

  SELECT 'success',
         'Production increased 3.4% year-over-year across all companies',
         6
  FROM (SELECT 1 AS dummy) x
) alerts
ORDER BY sort_order</CommandText>
      </Query>
      <Fields>
        <Field Name="alert_level">
          <DataField>alert_level</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="alert_message">
          <DataField>alert_message</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsPerCapita">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT
  c.company_name,
  c.governorate,
  ROUND(
    CAST(pr.produced_million_m3 AS FLOAT)
    / CAST(c.population_2022 AS FLOAT) * 1000000
  , 0) AS per_capita_m3
FROM [Egypt Water].[dbo].[Companies$] c
JOIN [Egypt Water].[dbo].[Production_Records$] pr
  ON c.company_id = pr.company_id
 AND pr.year = 2022
ORDER BY per_capita_m3 DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="company_name">
          <DataField>company_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="governorate">
          <DataField>governorate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="per_capita_m3">
          <DataField>per_capita_m3</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsRegionalSummary">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT
  CASE
    WHEN c.governorate IN ('Cairo','Giza')           THEN 'Metro Cairo'
    WHEN c.governorate IN ('Alexandria','Beheira')   THEN 'Lower Egypt'
    WHEN c.governorate IN ('Dakahlia','Sharqia')     THEN 'Delta'
    ELSE 'Upper Egypt'
  END AS region,
  ROUND(SUM(pr.produced_million_m3), 0)              AS total_production,
  ROUND(AVG(pr.loss_percentage), 1)                  AS avg_loss,
  SUM(qt.total_samples_2022)                         AS total_quality_tests,
  ROUND(AVG(qt.compliance_rate_pct), 1)              AS avg_compliance,
  COUNT(DISTINCT ws.source_id)                       AS source_count,
  ROUND(
    AVG(qt.compliance_rate_pct) * 0.5
    + (100 - AVG(pr.loss_percentage)) * 0.5
  , 1)                                               AS overall_score
FROM [Egypt Water].[dbo].[Companies$]          c
JOIN [Egypt Water].[dbo].[Production_Records$] pr ON c.company_id = pr.company_id
                                               AND pr.year = 2022
JOIN [Egypt Water].[dbo].[Quality_Tests$]      qt ON c.company_id = qt.company_id
JOIN [Egypt Water].[dbo].[Water_Sources$]      ws ON c.company_id = ws.company_id
GROUP BY
  CASE
    WHEN c.governorate IN ('Cairo','Giza')           THEN 'Metro Cairo'
    WHEN c.governorate IN ('Alexandria','Beheira')   THEN 'Lower Egypt'
    WHEN c.governorate IN ('Dakahlia','Sharqia')     THEN 'Delta'
    ELSE 'Upper Egypt'
  END
ORDER BY overall_score DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="region">
          <DataField>region</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="total_production">
          <DataField>total_production</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="avg_loss">
          <DataField>avg_loss</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="total_quality_tests">
          <DataField>total_quality_tests</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="avg_compliance">
          <DataField>avg_compliance</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="source_count">
          <DataField>source_count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="overall_score">
          <DataField>overall_score</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
