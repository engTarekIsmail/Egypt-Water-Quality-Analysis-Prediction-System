  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT governorate,
       total_samples_2022,
       non_compliant_samples,
       compliant_samples,
       compliance_rate_pct,
       main_quality_issue
FROM [Egypt Water].[dbo].[Quality_Tests$]
ORDER BY compliance_rate_pct ASC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
