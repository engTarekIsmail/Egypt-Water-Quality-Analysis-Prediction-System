  <DataSets>
    <DataSet Name="dsKPISummary">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT
  COUNT(*)                                        AS total_tests,
  ROUND(AVG(CAST(pH_compliant        AS FLOAT)) * 100, 1) AS ph_pct,
  ROUND(AVG(CAST(turbidity_compliant AS FLOAT)) * 100, 1) AS turbidity_pct,
  ROUND(AVG(CAST(TDS_compliant       AS FLOAT)) * 100, 1) AS tds_pct,
  ROUND(AVG(CAST(chlorine_compliant  AS FLOAT)) * 100, 1) AS chlorine_pct,
  ROUND(AVG(CAST(nitrate_compliant   AS FLOAT)) * 100, 1) AS nitrate_pct,
  ROUND(AVG(CAST(coliform_compliant  AS FLOAT)) * 100, 1) AS coliform_pct,
  ROUND(AVG(CAST(potable             AS FLOAT)) * 100, 1) AS potable_pct
FROM [Egypt Water].[dbo].[Test_Records]</CommandText>
      </Query>
      <Fields>
        <Field Name="total_tests">
          <DataField>total_tests</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ph_pct">
          <DataField>ph_pct</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="turbidity_pct">
          <DataField>turbidity_pct</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="tds_pct">
          <DataField>tds_pct</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="chlorine_pct">
          <DataField>chlorine_pct</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="nitrate_pct">
          <DataField>nitrate_pct</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="coliform_pct">
          <DataField>coliform_pct</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="potable_pct">
          <DataField>potable_pct</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsParamCompliance">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 'pH'        AS parameter, 
       ROUND(AVG(CAST(pH_compliant AS FLOAT))*100,1) AS compliance_rate,
       1 AS sort_order
FROM [Egypt Water].[dbo].[Test_Records]
UNION ALL
SELECT 'Turbidity',
       ROUND(AVG(CAST(turbidity_compliant AS FLOAT))*100,1), 2
FROM [Egypt Water].[dbo].[Test_Records]
UNION ALL
SELECT 'TDS',
       ROUND(AVG(CAST(TDS_compliant AS FLOAT))*100,1), 3
FROM [Egypt Water].[dbo].[Test_Records]
UNION ALL
SELECT 'Chlorine',
       ROUND(AVG(CAST(chlorine_compliant AS FLOAT))*100,1), 4
FROM [Egypt Water].[dbo].[Test_Records]
UNION ALL
SELECT 'Nitrate',
       ROUND(AVG(CAST(nitrate_compliant AS FLOAT))*100,1), 5
FROM [Egypt Water].[dbo].[Test_Records]
UNION ALL
SELECT 'Coliform',
       ROUND(AVG(CAST(coliform_compliant AS FLOAT))*100,1), 6
FROM [Egypt Water].[dbo].[Test_Records]
ORDER BY sort_order</CommandText>
      </Query>
      <Fields>
        <Field Name="parameter">
          <DataField>parameter</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="compliance_rate">
          <DataField>compliance_rate</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="sort_order">
          <DataField>sort_order</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsSeasonalAvg">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT
  season,
  ROUND(AVG(turbidity_NTU), 1)   AS avg_turbidity,
  ROUND(AVG(TDS_mg_L) / 10, 1)   AS avg_TDS_scaled,
  ROUND(AVG(pH), 2)               AS avg_pH,
  ROUND(AVG(chlorine_mg_L), 2)    AS avg_chlorine,
  CASE season
    WHEN 'Winter' THEN 1
    WHEN 'Spring' THEN 2
    WHEN 'Summer' THEN 3
    WHEN 'Autumn' THEN 4
  END AS season_order
FROM [Egypt Water].[dbo].[Test_Records]
GROUP BY season
ORDER BY season_order</CommandText>
      </Query>
      <Fields>
        <Field Name="season">
          <DataField>season</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="avg_turbidity">
          <DataField>avg_turbidity</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="avg_TDS_scaled">
          <DataField>avg_TDS_scaled</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="avg_pH">
          <DataField>avg_pH</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="avg_chlorine">
          <DataField>avg_chlorine</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="season_order">
          <DataField>season_order</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsSourceSummary">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT
  t.source_type,
  ROUND(AVG(t.pH), 2)                                      AS avg_pH,
  ROUND(AVG(t.turbidity_NTU), 1)                           AS avg_turbidity,
  ROUND(AVG(t.TDS_mg_L), 0)                                AS avg_TDS,
  ROUND(AVG(t.chlorine_mg_L), 2)                           AS avg_chlorine,
  ROUND(AVG(t.nitrate_mg_L), 1)                            AS avg_nitrate,
  ROUND(AVG(CAST(t.potable AS FLOAT)) * 100, 1)            AS potable_pct,
  COUNT(*)                                                  AS test_count
FROM [Egypt Water].[dbo].[Test_Records] t
GROUP BY t.source_type
ORDER BY potable_pct DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="source_type">
          <DataField>source_type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="avg_pH">
          <DataField>avg_pH</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="avg_turbidity">
          <DataField>avg_turbidity</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="avg_TDS">
          <DataField>avg_TDS</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="avg_chlorine">
          <DataField>avg_chlorine</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="avg_nitrate">
          <DataField>avg_nitrate</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="potable_pct">
          <DataField>potable_pct</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="test_count">
          <DataField>test_count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
