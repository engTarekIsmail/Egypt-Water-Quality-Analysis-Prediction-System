  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT source_name, source_type,
       annual_production_million_m3,
       daily_capacity_m3,
       water_quality_class,
       num_stations
FROM [Egypt Water].[dbo].[Water_Sources$]
ORDER BY annual_production_million_m3 DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="source_name">
          <DataField>source_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="source_type">
          <DataField>source_type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="annual_production_million_m3">
          <DataField>annual_production_million_m3</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="daily_capacity_m3">
          <DataField>daily_capacity_m3</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="water_quality_class">
          <DataField>water_quality_class</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="num_stations">
          <DataField>num_stations</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet2">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT source_type,
       COUNT(*) AS source_count,
       SUM(annual_production_million_m3) AS total_production
FROM [Egypt Water].[dbo].[Water_Sources$]
GROUP BY source_type</CommandText>
      </Query>
      <Fields>
        <Field Name="source_type">
          <DataField>source_type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="source_count">
          <DataField>source_count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="total_production">
          <DataField>total_production</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
