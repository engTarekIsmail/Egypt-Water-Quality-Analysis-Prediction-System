  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT company_id, company_name, governorate, company_type,
       population_2022, produced_million_m3_2022,
       loss_percentage, total_stations
FROM [Egypt Water].[dbo].[Companies$]
ORDER BY produced_million_m3_2022 DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="company_id">
          <DataField>company_id</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
